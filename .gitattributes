# Enforce LF line endings for source files regardless of client OS.
# Prevents ruff/black failing on Linux CI after a Windows commit.

* text=auto

*.py        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.svg       text eol=lf
*.sh        text eol=lf

# Windows-native files keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary — never touch
*.png  binary
*.jpg  binary
*.ico  binary
